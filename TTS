<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>STT/TTS Pipeline</title>
    <style>
        body { font-family: sans-serif; display: flex; justify-content: center; padding: 40px; }
        .card { width: 400px; padding: 20px; border: 1px solid #ccc; border-radius: 8px; }
        textarea { width: 100%; height: 120px; margin-bottom: 15px; box-sizing: border-box; }
        .controls { display: flex; gap: 10px; }
        button { flex: 1; padding: 10px; cursor: pointer; }
    </style>
</head>
<body>

<div class="card">
    <textarea id="text-box" placeholder="Speech output will appear here..."></textarea>
    <div class="controls">
        <button id="mic-btn">Start Mic</button>
        <button id="speak-btn">Speak</button>
    </div>
    <p id="status">Status: Idle</p>
</div>

<script>
    const textBox = document.getElementById('text-box');
    const micBtn = document.getElementById('mic-btn');
    const speakBtn = document.getElementById('speak-btn');
    const status = document.getElementById('status');

    // Speech to Text
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const recognition = new SpeechRecognition();
    recognition.continuous = true;
    recognition.interimResults = true;

    let isListening = false;

    micBtn.onclick = () => {
        if (!isListening) {
            recognition.start();
            micBtn.textContent = "Stop Mic";
            status.textContent = "Status: Listening...";
        } else {
            recognition.stop();
            micBtn.textContent = "Start Mic";
            status.textContent = "Status: Idle";
        }
        isListening = !isListening;
    };

    recognition.onresult = (event) => {
        let transcript = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
            transcript += event.results[i][0].transcript;
        }
        textBox.value = transcript;
    };

    // Text to Speech
    const synth = window.speechSynthesis;

    speakBtn.onclick = () => {
        if (synth.speaking) {
            synth.cancel();
        }
        
        const utterance = new SpeechSynthesisUtterance(textBox.value);
        utterance.onstart = () => status.textContent = "Status: Speaking...";
        utterance.onend = () => status.textContent = "Status: Idle";
        
        synth.speak(utterance);
    };

    recognition.onerror = (e) => {
        status.textContent = "Error: " + e.error;
        isListening = false;
        micBtn.textContent = "Start Mic";
    };
</script>

</body>
</html>
